# -----------------------------------------------------------------------------
# LLM provider — Gemini recommandé (tier free généreux, Pro dispo sur ta clef)
# -----------------------------------------------------------------------------
LLM_PROVIDER=gemini

# --- Gemini (principal) -------------------------------------------------------
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview

# --- Anthropic (optionnel, uniquement si LLM_PROVIDER=anthropic) -------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- PageSpeed Insights (optionnel, free 25 000 req/jour) --------------------
# Get a key at https://developers.google.com/speed/docs/insights/v5/get-started
# Si absent : Core Web Vitals marqués "estimation" dans les rapports.
PAGESPEED_API_KEY=

# --- Playwright (optionnel, fallback pour sites JS/SPA) ----------------------
# Coût : ~500MB de container (Chromium). En prod on garde OFF pour alléger.
# Installer une fois en local : `playwright install chromium`
PLAYWRIGHT_ENABLED=false

# --- CORS ---------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001
# Regex pour autoriser toutes les previews Vercel (prod uniquement) :
# ALLOWED_ORIGIN_REGEX=^https://audit-bureau-.*\.vercel\.app$

# --- Auth (mot de passe partagé) ---------------------------------------------
# Si vide, l'API tourne sans auth (mode dev). En prod, mettre un password
# pour empêcher quiconque de consommer ta clé Gemini.
APP_PASSWORD=

# --- Cron interne (APScheduler, in-process) ---------------------------------
# Refresh automatique des sitemap watchers / perf monitors / SEO campaigns.
# Désactivé par défaut. Activer en prod pour avoir du vrai monitoring.
# Fuseau horaire : UTC. Format cron 5 champs (min h jour mois weekday).
SCHEDULER_ENABLED=0
# SCHEDULER_SITEMAP_CRON=0 6 * * *      # tous les jours 06:00 UTC
# SCHEDULER_PERF_CRON=30 6 * * *        # tous les jours 06:30 UTC
# SCHEDULER_SEO_CRON=0 7 * * 1          # lundi 07:00 UTC

# --- Base de données ---------------------------------------------------------
# Défaut (dev) : SQLite local dans api/data/audit-bureau.db
# Prod : postgresql+psycopg://user:password@host:5432/dbname
# DATABASE_URL=sqlite:///api/data/audit-bureau.db
